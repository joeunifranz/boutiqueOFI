# Copia este archivo como .env (misma carpeta que index.php)
# y rellena con tus datos.
#
# Nota: en Windows/XAMPP, esto es más simple que configurar SetEnv en Apache.

# --- Correo (SMTP) ---
BOUTIQUE_MAIL_DRIVER=gmail_api

# Remitente (debe coincidir con la cuenta autenticada en la mayoría de SMTP)
BOUTIQUE_FROM_EMAIL=joeunifranz@gmail.com

# Servidor SMTP (Gmail típico)
BOUTIQUE_SMTP_HOST=smtp.gmail.com
BOUTIQUE_SMTP_PORT=587
BOUTIQUE_SMTP_SECURE=tls

# Credenciales
BOUTIQUE_SMTP_USERNAME=joeunifranz@gmail.com
BOUTIQUE_SMTP_PASSWORD=TU_APP_PASSWORD_DE_GMAIL

# TLS/CA (si tienes error de certificados en Windows, para pruebas puedes poner false)
BOUTIQUE_SMTP_VERIFY_PEER=true
# BOUTIQUE_SMTP_CAFILE=C:\ruta\a\cacert.pem
# BOUTIQUE_SMTP_CAPATH=
